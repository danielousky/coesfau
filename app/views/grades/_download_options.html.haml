- # Lista en Excel de asignatuas aprobadas
= link_to "/grades/#{grade.id}/kardex.pdf", class: 'btn btn-success float-end mb-3 me-2', target: '_blank', rel: "noopener noreferrer" do
	.fa.fa-download.fa-list
	Kardex PDF
- if current_user&.admin? and session[:rol].eql? 'admin'
	- if grade.academic_records.aprobado.any?
		= link_to "/grades/#{grade.id}/kardex.pdf?approved=true", class: 'btn btn-success float-end mb-3 me-2', target: '_blank', rel: "noopener noreferrer" do
			.fa.fa-download.fa-list
			Kardex Aprobadas PDF
		= link_to "/grades/#{grade.id}/export_approved_subjects.xls", class: 'btn btn-primary float-end mb-3 me-2', target: '_blank', rel: "noopener noreferrer" do
			.fa.fa-download.fa-table
			Asignaturas Aprobadas Excel
	- else
		.btn.btn-secondary.disabled.float-end.mb-3.me-2{toggle: 'tooltip', title: 'No hay asignaturas aprobadas'}
			.fa.fa-download.fa-list
			Kardex Aprobadas PDF

		.btn.btn-secondary.disabled.float-end.mb-3.me-2{toggle: 'tooltip', title: 'No hay asignaturas aprobadas'}
			.fa.fa-download.fa-list
			Asignaturas Aprobadas Excel		

	